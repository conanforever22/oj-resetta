// ==UserScript==
// @name         OJ Resetta - 题目搬运追踪
// @namespace    https://github.com/conanforever22/oj-resetta
// @version      1.0.0
// @description  在各大 OJ 页面显示题目是否已搬运到自有 Hydro OJ；在自有 OJ 显示题目来源
// @author       conanforever22
// @match        https://www.luogu.com.cn/problem/*
// @match        https://www.luogu.com/problem/*
// @match        https://codeforces.com/problemset/problem/*
// @match        https://codeforces.com/contest/*/problem/*
// @match        https://atcoder.jp/contests/*/tasks/*
// @match        http://__YOUR_HYDRO_DOMAIN__/d/repo/p/*
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_xmlhttpRequest
// @grant        GM_registerMenuCommand
// ==/UserScript==

(function () {
    "use strict";

    // ================================================================
    // 私有配置（复制此文件为 oj-tracker.user.js 后填写你的域名）
    // ================================================================

    const HYDRO_PROBLEM_URL = "http://__YOUR_HYDRO_DOMAIN__/d/repo/p/{id}";

    const DATA_URL = "https://conanforever22.github.io/oj-resetta/data.json";

    const SOURCE_DISPLAY_NAMES = {
        luogu:      "洛谷",
        codeforces: "Codeforces",
        atcoder:    "AtCoder",
    };

    // ================================================================
    // URL → OJ 检测规则
    // ================================================================

    const SOURCE_URL_TEMPLATES = {
        luogu:      (id) => `https://www.luogu.com.cn/problem/${id}`,
        codeforces: (id) => {
            const m = id.match(/^cf(\d+)([a-z]\d*)$/i);
            if (m) return `https://codeforces.com/problemset/problem/${m[1]}/${m[2].toUpperCase()}`;
            return null;
        },
        atcoder:    (id) => {
            const clean = id.toLowerCase().replace(/_/g, "");
            const m = clean.match(/^([a-z]+\d{1,3})([a-z].*|[1-8])$/);
            if (m) return `https://atcoder.jp/contests/${m[1]}/tasks/${m[1]}_${m[2]}`;
            return null;
        },
    };

    // ================================================================
    // 数据缓存
    // ================================================================

    const CACHE_KEY = "oj_resetta_data";
    const CACHE_TTL = 3600000; // 1 小时

    function fetchData() {
        return new Promise((resolve, reject) => {
            const cached = GM_getValue(CACHE_KEY);
            if (cached && Date.now() - cached.ts < CACHE_TTL) {
                resolve(cached.data);
                return;
            }

            GM_xmlhttpRequest({
                method: "GET",
                url: DATA_URL,
                timeout: 10000,
                onload(resp) {
                    try {
                        const data = JSON.parse(resp.responseText);
                        GM_setValue(CACHE_KEY, { ts: Date.now(), data: data });
                        resolve(data);
                    } catch (e) {
                        if (cached) resolve(cached.data); // fallback to stale cache
                        else reject(e);
                    }
                },
                onerror() {
                    if (cached) resolve(cached.data);
                    else reject(new Error("fetch failed"));
                },
                ontimeout() {
                    if (cached) resolve(cached.data);
                    else reject(new Error("fetch timeout"));
                },
            });
        });
    }

    // ================================================================
    // URL 识别 — 返回 { type: "source"|"self", oj, normalizedId }
    // ================================================================

    function detectPage() {
        const url = location.href;

        // --- Codeforces ---
        let m = url.match(/codeforces\.com\/problemset\/problem\/(\d+)\/([A-Za-z0-9]+)/);
        if (!m) m = url.match(/codeforces\.com\/contest\/(\d+)\/problem\/([A-Za-z0-9]+)/);
        if (m) {
            return {
                type: "source",
                oj: "codeforces",
                normalizedId: "cf" + (m[1] + m[2]).toLowerCase().replace(/[\/\-_]/g, ""),
            };
        }

        // --- AtCoder ---
        m = url.match(/atcoder\.jp\/contests\/[^\/]+\/tasks\/([A-Za-z0-9_]+)/);
        if (m) {
            return {
                type: "source",
                oj: "atcoder",
                normalizedId: m[1].toLowerCase().replace(/_/g, ""),
            };
        }

        // --- 洛谷 ---
        m = url.match(/luogu\.com(?:\.cn)?\/problem\/([A-Za-z0-9_]+)/);
        if (m) {
            const rawId = m[1];
            for (const [prefix, ojKey] of Object.entries(REMOTE_JUDGE_PREFIXES)) {
                if (rawId.startsWith(prefix)) {
                    return {
                        type: "source",
                        oj: ojKey,
                        normalizedId: ojKey === "atcoder"
                            ? rawId.slice(prefix.length).toLowerCase().replace(/_/g, "")
                            : (ojKey === "codeforces"
                                ? "cf" + rawId.slice(prefix.length).toLowerCase().replace(/[\/\-_]/g, "")
                                : rawId.slice(prefix.length)),
                    };
                }
            }
            return { type: "source", oj: "luogu", normalizedId: rawId };
        }

        // --- 自有 Hydro ---
        m = url.match(/\/d\/\w+\/p\/(\d+)/);
        if (m) {
            return { type: "self", oj: "_self", normalizedId: m[1] };
        }

        return null;
    }

    // 远程前缀表（由 data.json 提供，脚本中也硬编码一份作为 fallback）
    const REMOTE_JUDGE_PREFIXES = {
        "AT_": "atcoder",
        "CF":  "codeforces",
    };

    // ================================================================
    // 状态提示（页面标题 + Tampermonkey 菜单）
    // ================================================================

    function setPageTitle(prefix) {
        if (!document.title.startsWith(prefix)) {
            document.title = prefix + document.title;
        }
    }

    function registerMenu(label, url) {
        if (url) {
            GM_registerMenuCommand(label, () => { window.open(url, "_blank"); });
        } else {
            GM_registerMenuCommand(label, () => {});
        }
    }

    // ================================================================
    // 主流程
    // ================================================================

    async function main() {
        const page = detectPage();
        if (!page) return;

        let data;
        try {
            data = await fetchData();
        } catch (e) {
            console.warn("[OJ Resetta] Failed to load data:", e);
            return;
        }
        if (!data) return;

        // --- 自有 Hydro：查来源 ---
        if (page.type === "self") {
            const info = data.by_my_id ? data.by_my_id[page.normalizedId] : null;
            if (info) {
                const display = SOURCE_DISPLAY_NAMES[info.source] || info.source;
                const srcUrl = info.source_url ||
                    (SOURCE_URL_TEMPLATES[info.source] ? SOURCE_URL_TEMPLATES[info.source](info.source_id) : null);
                setPageTitle("\u{1F7E2} ");
                registerMenu(
                    `\u{1F7E2} \u6765\u6E90: ${display} ${info.source_id}`,
                    srcUrl
                );
            } else {
                setPageTitle("\u{1F7E1} ");
                registerMenu("\u{1F7E1} \u539F\u521B", null);
            }
            return;
        }

        // --- 外部 OJ：查是否已搬运 ---
        if (page.type === "source") {
            const sub = data.by_source ? data.by_source[page.oj] : null;
            const myId = sub ? sub[page.normalizedId] : null;
            if (myId) {
                const hydroUrl = HYDRO_PROBLEM_URL.replace("{id}", myId);
                setPageTitle("\u{2714} ");
                registerMenu(
                    `\u{1F7E2} \u5DF2\u642C\u8FD0 \u2192 Hydro #${myId}`,
                    hydroUrl
                );
            }
        }
    }

    // 等 DOM 就绪再执行
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", main);
    } else {
        main();
    }
})();
